# Sheety API (Google Sheet Access)
SHEETY_PRICES_ENDPOINT=https://api.sheety.co/your_id_here/flightDeals/prices
SHEETY_USERS_ENDPOINT=https://api.sheety.co/your_id_here/flightDeals/users
SHEETY_USERNAME=your_sheety_username
